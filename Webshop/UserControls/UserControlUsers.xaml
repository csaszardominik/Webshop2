<UserControl x:Class="Webshop.UserControls.UserControlUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Webshop.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <StackPanel>
        <DataGrid
        x:Name="datagridFelhasznalok"
        Width="1100"
        Height="600"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        IsReadOnly="True"
        SelectionChanged="datagridFelhasznalok_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                <DataGridTextColumn Binding="{Binding FelhasznaloNev}" Header="Felh.név:" />
                <DataGridTextColumn Binding="{Binding TeljesNev}" Header="Teljes név:" />
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel Margin="130,10,130,0">
            <StackPanel Width="300" Background="LightGray">
                <TextBlock>Felhasználónév:</TextBlock>
                <TextBox x:Name="felhasznalonevText" />
                <TextBlock>
                Teljes név:
                </TextBlock>
                <TextBox x:Name="teljesnevText" />
                <TextBlock>Jelszó:</TextBlock>
                <PasswordBox x:Name="jelszoText" />
            </StackPanel>
            <StackPanel>
                <Button
                x:Name="mentesBtn"
                Width="200"
                Background="Green"
                Click="mentesBtn_Click"
                Content="Mentés"
                Foreground="White"
                Visibility="Visible" />
                <Button
                x:Name="torlesBtn"
                Width="200"
                Background="Red"
                Click="torlesBtn_Click"
                Content="Törlés"
                Foreground="White"
                Visibility="Hidden" />
            </StackPanel>

        </WrapPanel>
    </StackPanel>
</UserControl>
